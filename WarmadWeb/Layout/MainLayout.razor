@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Nav
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" />
<MudSnackbarProvider />

<div class="mobile-shell">

    <header class="mobile-topbar">
        @if (_isSubPage)
        {
            <button class="topbar-back" @onclick="GoBack">
                <MudIcon Icon="@Icons.Material.Rounded.ArrowBackIos" Style="font-size:1.125rem; color:#CBD5E1" />
            </button>
            <span class="topbar-title">@_pageTitle</span>
            <div class="topbar-spacer"></div>
        }
        else
        {
            <div class="topbar-brand">
                <div class="topbar-logo">W</div>
                <div>
                    <div class="topbar-brand-name">Warmad</div>
                    <div class="topbar-brand-sub">POS System</div>
                </div>
            </div>
            <div class="topbar-date">@_today</div>
        }
    </header>

    <main class="mobile-content @(_isSubPage ? "" : "has-bottomnav")">
        @Body
    </main>

    @if (!_isSubPage)
    {
        <nav class="bottom-nav">
            <a href="/" class="bnav-item @(_path == "/" ? "active" : "")">
                <MudIcon Icon="@Icons.Material.Rounded.Home" Class="bnav-icon" />
                <span class="bnav-label">Beranda</span>
            </a>
            <a href="/kasir" class="bnav-item @(_path == "/kasir" ? "active" : "")">
                <MudIcon Icon="@Icons.Material.Rounded.PointOfSale" Class="bnav-icon" />
                <span class="bnav-label">Kasir</span>
            </a>
            <a href="/produk" class="bnav-item @(_path == "/produk" ? "active" : "")">
                <MudIcon Icon="@Icons.Material.Rounded.Inventory2" Class="bnav-icon" />
                <span class="bnav-label">Produk</span>
            </a>
            <a href="/laporan" class="bnav-item @(_path == "/laporan" ? "active" : "")">
                <MudIcon Icon="@Icons.Material.Rounded.BarChart" Class="bnav-icon" />
                <span class="bnav-label">Laporan</span>
            </a>
            <a href="/pengaturan" class="bnav-item @(_path == "/pengaturan" ? "active" : "")">
                <MudIcon Icon="@Icons.Material.Rounded.Settings" Class="bnav-icon" />
                <span class="bnav-label">Setelan</span>
            </a>
        </nav>
    }

</div>

@code {
    private static readonly HashSet<string> MainPages = new(StringComparer.OrdinalIgnoreCase)
        { "/", "/kasir", "/produk", "/laporan", "/pengaturan" };

    private static readonly Dictionary<string, string> PageTitles = new(StringComparer.OrdinalIgnoreCase)
    {
        ["/"]            = "Beranda",
        ["/kasir"]       = "Kasir",
        ["/produk"]      = "Produk",
        ["/laporan"]     = "Laporan",
        ["/pengaturan"]  = "Pengaturan",
        ["/pengeluaran"] = "Pengeluaran",
        ["/stok"]        = "Stok",
    };

    private string _path      = "/";
    private bool   _isSubPage = false;
    private string _pageTitle = "";
    private string _today     = "";

    protected override void OnInitialized()
    {
        var hari  = new[] { "Minggu", "Senin", "Selasa", "Rabu", "Kamis", "Jumat", "Sabtu" };
        var bulan = new[] { "", "Jan", "Feb", "Mar", "Apr", "Mei", "Jun", "Jul", "Agu", "Sep", "Okt", "Nov", "Des" };
        var now   = DateTime.Now;
        _today = $"{hari[(int)now.DayOfWeek]}, {now.Day} {bulan[now.Month]} {now.Year}";

        Nav.LocationChanged += OnLocationChanged;
        UpdatePageState(Nav.Uri);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdatePageState(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void UpdatePageState(string uri)
    {
        var baseUri = Nav.BaseUri.TrimEnd('/');
        _path = uri.StartsWith(baseUri, StringComparison.OrdinalIgnoreCase)
            ? uri[baseUri.Length..]
            : "/";
        if (string.IsNullOrEmpty(_path)) _path = "/";

        _isSubPage = !MainPages.Contains(_path);
        PageTitles.TryGetValue(_path, out _pageTitle!);
        _pageTitle ??= _path.TrimStart('/');
    }

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary               = "#10B981",
            PrimaryContrastText   = "#FFFFFF",
            Secondary             = "#F59E0B",
            SecondaryContrastText = "#1F2937",
            Background            = "#F1F5F9",
            Surface               = "#FFFFFF",
            DrawerBackground      = "#0F172A",
            DrawerText            = "#CBD5E1",
            DrawerIcon            = "#64748B",
            AppbarBackground      = "#0F172A",
            AppbarText            = "#FFFFFF",
            TextPrimary           = "#0F172A",
            TextSecondary         = "#64748B",
            TextDisabled          = "#CBD5E1",
            Divider               = "#E2E8F0",
            LinesDefault          = "#E2E8F0",
            Success               = "#10B981",
            SuccessContrastText   = "#FFFFFF",
            Error                 = "#F43F5E",
            ErrorContrastText     = "#FFFFFF",
            Warning               = "#F59E0B",
            WarningContrastText   = "#1F2937",
            Info                  = "#6366F1",
            InfoContrastText      = "#FFFFFF",
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "10px",
            AppbarHeight        = "58px",
        }
    };
}